#:kivy 2.0

BoxLayout:
    orientation: 'vertical'
    padding: 10
    spacing: 10

    canvas.before:
        Color:
            rgba: 0.1, 0.1, 0.1, 1
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        size_hint_y: 0.08

        canvas.before:
            Color:
                rgba: 0.2, 0.2, 0.2, 1
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: app.connection_status
            font_size: '14sp'
            color: (0, 1, 0, 1) if app.is_connected else (1, 0, 0, 1)

    BoxLayout:
        orientation: 'vertical'
        size_hint_y: 0.92
        spacing: 12

        BoxLayout:
            orientation: 'vertical'
            size_hint_y: 0.32

            canvas.before:
                Color:
                    rgba: 0.15, 0.15, 0.15, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            Label:
                text: 'Posture Image'
                size_hint_y: 0.18
                font_size: '15sp'
                color: 0.7, 0.7, 0.7, 1

            Image:
                id: posture_image
                source: app.image_source
                allow_stretch: True
                keep_ratio: True

        BoxLayout:
            orientation: 'vertical'
            size_hint_y: 0.2

            canvas.before:
                Color:
                    rgba: 0.15, 0.15, 0.15, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            Label:
                text: 'Current Posture'
                size_hint_y: 0.3
                font_size: '16sp'
                color: 0.7, 0.7, 0.7, 1

            Label:
                text: app.posture_label
                size_hint_y: 0.7
                font_size: '24sp'
                color: 0, 1, 0, 1

        BoxLayout:
            orientation: 'vertical'
            size_hint_y: 0.2

            canvas.before:
                Color:
                    rgba: 0.15, 0.15, 0.15, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            Label:
                text: 'Time Worked'
                size_hint_y: 0.3
                font_size: '16sp'
                color: 0.7, 0.7, 0.7, 1

            Label:
                text: app.time_worked
                size_hint_y: 0.7
                font_size: '34sp'
                color: 0.2, 0.8, 1, 1

        BoxLayout:
            orientation: 'vertical'
            size_hint_y: 0.2
            padding: 10
            spacing: 6

            canvas.before:
                Color:
                    rgba: 0.15, 0.15, 0.15, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            Label:
                text: 'Reminder Interval (Seconds)'
                size_hint_y: 0.2
                font_size: '14sp'
                color: 0.7, 0.7, 0.7, 1

            Label:
                text: str(int(app.interval_minutes)) + " sec"
                size_hint_y: 0.2
                font_size: '18sp'
                color: 1, 0.84, 0, 1

            Slider:
                min: 1
                max: 60
                value: app.interval_minutes
                step: 1
                size_hint_y: 0.4
                on_value: app.on_interval_value_change(self.value)

        BoxLayout:
            orientation: 'vertical'
            size_hint_y: 0.08
            padding: 8

            canvas.before:
                Color:
                    rgba: 0.1, 0.1, 0.1, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            Label:
                text: 'Topics: posture/status → posture/timer'
                font_size: '11sp'
                color: 0.5, 0.5, 0.5, 1